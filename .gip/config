[core]
        repositoryformatversion = 0
        filemode = true
        bare = false
        logallrefupdates = true

[remote "origin"]
        url = https://github.com/tanazd1/termux-utils
        fetch = +refs/heads/*:refs/remotes/origin/*

[branch "main"]
        remote = origin
        merge = refs/heads/main

[custom]
        description = "Custom Properties repository for Termux utilities and scripts"
        main_branch = main
        
