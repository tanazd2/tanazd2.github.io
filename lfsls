#!/data/data/com.termux/files/usr/bin/bash
# lfsls: list all LFS-tracked files or check a specific file
set -e

if [ -z "$1" ]; then
    git-lfs ls-files
else
    file="$1"
    if git-lfs ls-files | grep -q "[[:space:]]$file\$"; then
        echo "$file is LFS-tracked ✅"
    else
        echo "$file is NOT LFS-tracked ❌"
    fi
fi
