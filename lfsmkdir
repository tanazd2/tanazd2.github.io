#!/data/data/com.termux/files/usr/bin/bash
# lfsmkdir: add a directory and all its contents to LFS
set -e

dir="$1"
if [ -z "$dir" ]; then
    echo "Usage: lfsmkdir <directory>"
    exit 1
fi

if [ ! -d "$dir" ]; then
    echo "Directory '$dir' does not exist ❌"
    exit 1
fi

# Track all files recursively
git lfs track "$dir/**"
git add "$dir"
echo "Directory '$dir' and all contents added to LFS ✅"
