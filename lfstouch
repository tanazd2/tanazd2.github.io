#!/data/data/com.termux/files/usr/bin/bash
# lfstouch: add a single file to LFS
set -e

file="$1"
if [ -z "$file" ]; then
    echo "Usage: lfstouch <file>"
    exit 1
fi

if [ ! -f "$file" ]; then
    echo "File '$file' does not exist ❌"
    exit 1
fi

git lfs track "$file"
git add "$file"
echo "File '$file' added to LFS ✅"
